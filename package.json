{
  "name": "markpad",
  "version": "1.6.1",
  "description": "A Typora-like WYSIWYG Markdown editor for macOS, built with Electron + Vditor",
  "main": "main.js",
  "author": "MarkPad Contributors",
  "license": "MIT",
  "homepage": "https://github.com/SirKayZh/markpad",
  "repository": {
    "type": "git",
    "url": "https://github.com/SirKayZh/markpad.git"
  },
  "keywords": [
    "markdown",
    "editor",
    "typora",
    "electron",
    "vditor",
    "macos",
    "wysiwyg"
  ],
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "dmg": "bash scripts/build-dmg.sh",
    "win": "env -u ELECTRON_RUN_AS_NODE npx electron-builder --win --x64",
    "win:portable": "env -u ELECTRON_RUN_AS_NODE npx electron-builder --win portable --x64",
    "release:patch": "bash scripts/release.sh patch",
    "release:minor": "bash scripts/release.sh minor",
    "release:major": "bash scripts/release.sh major"
  },
  "build": {
    "appId": "com.markpad.app",
    "productName": "MarkPad",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/vditor/dist/**/*",
      "node_modules/html-docx-js/dist/**/*",
      "node_modules/prismjs/prism.js",
      "node_modules/prismjs/themes/prism.css",
      "node_modules/prismjs/components/prism-json.min.js",
      "node_modules/prismjs/components/prism-yaml.min.js",
      "node_modules/prismjs/components/prism-markup.min.js"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}-setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MarkPad"
    },
    "portable": {
      "artifactName": "${productName}-${version}-${arch}-portable.${ext}"
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdown",
          "mkd",
          "mdtext"
        ],
        "name": "Markdown Document",
        "description": "Markdown 文档",
        "role": "Editor",
        "rank": "Owner"
      },
      {
        "ext": [
          "txt"
        ],
        "name": "Text Document",
        "description": "纯文本文档",
        "role": "Editor",
        "rank": "Alternate"
      },
      {
        "ext": [
          "xml",
          "json",
          "jsonl",
          "yml",
          "yaml"
        ],
        "name": "Code / Config File",
        "description": "代码/配置文件",
        "role": "Editor",
        "rank": "Alternate"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "html-docx-js": "^0.3.1",
    "prismjs": "^1.30.0",
    "vditor": "^3.10.4"
  }
}
